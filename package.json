{
  "name": "@kitware/vtk-wasm",
  "version": "0.0.0",
  "description": "A WebAssembly port of the VTK library",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kitware/vtk-wasm.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:debug": "vite build --sourcemap -m dev",
    "build:esm": "vite build",
    "build:viewer": "vite build -c vite.config.viewer.js",
    "build:vtk": "vite build -c vite.config.standalone.js",
    "build": "npm run build:esm && npm run build:vtk && npm run build:viewer",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "prettier .  --write",
    "lint": "eslint --fix src",
    "clean": "rimraf dist",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "3.5.3",
    "rimraf": "^6.0.1",
    "semantic-release": "24.2.7",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "vite": "^6.2.4",
    "vitepress": "^1.6.3"
  },
  "files": [
    "dist/**/*"
  ],
  "exports": {
    "./remote": "./esm/remote.mjs",
    "./vtk": "./esm/vtk.mjs",
    "./viewer": "./esm/viewer.mjs",
    "./viewer-umd.js": "./umd/viewer.umd.js",
    "./vtk-umd.js": "./umd/vtk.umd.js",
    "./viewer.css": "./umd/viewer.css",
    "./umd/*": "./umd/*",
    "./esm/*": "./esm/*"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      [
        "@semantic-release/github",
        {
          "successCommentCondition": "<% return branch.name === 'main'; %>"
        }
      ]
    ]
  }
}
